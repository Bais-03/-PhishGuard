# # === Redis ===
# REDIS_URL=redis://localhost:6379

# # === PostgreSQL ===
# DATABASE_URL=postgresql+asyncpg://phishguard:phishguard_secret@localhost:5432/phishguard

# # === App Settings ===
# DEBUG=true
# LOG_LEVEL=INFO
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# # === Rate Limiting ===
# RATE_LIMIT_PER_MINUTE=10
# RATE_LIMIT_PER_DAY=100

# # === Playwright ===
# PLAYWRIGHT_TIMEOUT_MS=15000
# ENABLE_PLAYWRIGHT=true

# # === Tranco ===
# TRANCO_FILE_PATH=data/tranco_top1m.csv

# ============================================
# PHISHGUARD ENVIRONMENT VARIABLES
# ============================================

# === API Keys (External Services) ===
VT_API_KEY=your_virustotal_api_key_here
GOOGLE_SAFE_BROWSING_KEY=your_google_safe_browsing_key_here
ABUSEIPDB_KEY=your_abuseipdb_key_here

# === Redis (Caching & Queue) ===
REDIS_URL=redis://localhost:6379
REDIS_QUEUE_NAME=phishguard:analysis:queue
REDIS_RESULT_TTL=86400  # 24 hours

# === PostgreSQL (Audit Logging) ===
DATABASE_URL=postgresql+asyncpg://phishguard:phishguard_secret@localhost:5432/phishguard
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# === App Settings ===
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=PhishGuard
APP_VERSION=2.0.0
SECRET_KEY=your-super-secret-key-change-this-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:80

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_DAY=1000
RATE_LIMIT_PER_HOUR=500

# === Playwright (Deep Content Analysis) ===
ENABLE_PLAYWRIGHT=true
PLAYWRIGHT_TIMEOUT_MS=15000
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_MAX_PAGES=10

# === Tranco (Domain Ranking) ===
TRANCO_FILE_PATH=data/tranco_top1m.csv
TRANCO_AUTO_UPDATE=true
TRANCO_UPDATE_DAYS=7

# === File Upload Settings ===
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=.eml,.msg
UPLOAD_TEMP_DIR=/tmp/phishguard_uploads

# === Email Forwarding (NEW) ===
# SendGrid Configuration
SENDGRID_ENABLED=false
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_WEBHOOK_SECRET=your_webhook_secret

# Mailgun Configuration
MAILGUN_ENABLED=false
MAILGUN_API_KEY=your_mailgun_api_key
MAILGUN_DOMAIN=yourdomain.com
MAILGUN_WEBHOOK_SECRET=your_webhook_secret

# SMTP for outgoing results
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=analyze@phishguard.com
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true

# Forward Email Address
FORWARD_EMAIL_ADDRESS=analyze@phishguard.com

# === Async Queue (Celery/Redis) ===
QUEUE_ENABLED=true
QUEUE_WORKER_COUNT=2
QUEUE_TASK_TIMEOUT=300  # 5 minutes
QUEUE_MAX_RETRIES=3

# === Security ===
JWT_EXPIRATION_HOURS=24
BCRYPT_ROUNDS=12
SESSION_TIMEOUT_MINUTES=30

# === Monitoring ===
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=your_sentry_dsn_optional

# === Docker / Production ===
DOCKER_ENV=false
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WORKER_CONCURRENCY=4
